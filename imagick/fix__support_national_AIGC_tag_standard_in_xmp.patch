Index: coders/png.c
IDEA additional info:
Subsystem: com.intellij.openapi.diff.impl.patch.CharsetEP
<+>UTF-8
===================================================================
diff --git a/coders/png.c b/coders/png.c
--- a/coders/png.c	(revision 04ee6cec572251279db13cba52a59eaef12f5652)
+++ b/coders/png.c	(date 1761909231000)
@@ -11108,7 +11108,7 @@
               }
 #endif /* WRITE_iCCP */
 
-            if (LocaleCompare(name,"exif") == 0)
+            if (LocaleCompare(name,"exif") == 0 || LocaleCompare(name,"xmp") == 0)
               {
                    /* Do not write hex-encoded ICC chunk; we will
                       write it later as an eXIf chunk */
@@ -11127,6 +11127,45 @@
         name=GetNextImageProfile(image);
       }
     }
+  }
+
+  /* write xmp data in iTXt */
+  {
+    ResetImageProfileIterator(image);
+    for (name=GetNextImageProfile(image); name != (char *) NULL; ) {
+      profile=GetImageProfile(image,name);
+      if (profile != (StringInfo *) NULL) {
+        if (LocaleCompare(name,"xmp") == 0) {
+          u_int32_t profile_data_len = GetStringInfoLength(profile);
+          png_textp text;
+          png_uint_32 allocated_length, description_length;
+
+          description_length = 3;
+          allocated_length = (png_uint_32) (2*profile_data_len+(profile_data_len >> 5)+description_length+
+     20);
+
+          text=(png_textp) png_malloc(ping,(png_alloc_size_t) sizeof(png_text));
+          (void) memset(text,0,sizeof(png_text));
+          text[0].text=(png_charp) png_malloc(ping,(png_alloc_size_t)allocated_length);
+          text[0].key=(png_charp) png_malloc(ping,(png_alloc_size_t) 80);
+
+          memcpy(text[0].text, GetStringInfoDatum(profile), profile_data_len);
+          text[0].text[profile_data_len]='\0';
+          text[0].key[0]='\0';
+          (void) ConcatenateMagickString(text[0].key,"XML:com.adobe.xmp\x00", MagickPathExtent);
+          text[0].compression = 1;
+          text[0].text_length = profile_data_len;
+
+          png_set_text(ping, ping_info, text, 1);
+
+          png_free(ping,text[0].text);
+          png_free(ping,text[0].key);
+          png_free(ping,text);
+        }
+      }
+      name=GetNextImageProfile(image);
+    }
+
   }
 
 #if defined(PNG_WRITE_sRGB_SUPPORTED)
